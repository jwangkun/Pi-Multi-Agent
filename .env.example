# LLM Provider Configuration (OpenAI-compatible)
# Supports: DeepSeek, OpenAI, StepFun, SiliconFlow, Moonshot, GLM Coding Plan, etc.

# Uncomment and set your provider:

# DeepSeek (default)
# LLM_API_KEY=your-api-key-here
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# OpenAI
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# StepFun
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://api.stepfun.com/step_plan/v1
# LLM_MODEL=step-3.7-flash

# GLM Coding Plan (Zhipu) — Requires Coding Plan, not the regular API
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# LLM_MODEL=glm-5.1

# SiliconFlow
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.siliconflow.cn/v1
# LLM_MODEL=deepseek-ai/DeepSeek-V3

# Moonshot
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k

# Optional: Server port (default: 3001)
# PORT=3001
